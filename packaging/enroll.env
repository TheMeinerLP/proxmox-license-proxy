# Configuration for the proxmox-license-proxy enroll/renew timer.
# Read by proxmox-license-proxy-enroll.service (EnvironmentFile). Each variable
# maps to the matching `client enroll` flag; a flag passed by hand still wins.
#
# Install this file to /etc/pmox/enroll.env, set PMOX_ENROLL_SERVER, then enable
# the timer:  systemctl enable --now proxmox-license-proxy-enroll.timer

# Required: the proxy server URL (the enroll command does nothing without it).
PMOX_ENROLL_SERVER=https://192.168.68.100

# Optional. Products to enroll (default: auto-detect PVE/PBS/PMG on this host).
#PMOX_ENROLL_PRODUCTS=pve,pbs

# Optional. Subscription level c|b|s|p (default: community) and PVE CPU sockets.
#PMOX_ENROLL_LEVEL=c
#PMOX_ENROLL_SOCKETS=1

# Optional. Account key path (default: /etc/pmox/account.key), reported host id
# (default: machine-id), contact recorded with the account, and the proxy IP used
# for the /etc/hosts redirect (default: taken from PMOX_ENROLL_SERVER).
#PMOX_ENROLL_ACCOUNT_KEY=/etc/pmox/account.key
#PMOX_ENROLL_SERVERID=
#PMOX_ENROLL_CONTACT=
#PMOX_ENROLL_IP=

# Optional. Set to 1 to only fetch keys without applying them / without touching
# the CA trust store and /etc/hosts.
#PMOX_ENROLL_NO_SET=0
#PMOX_ENROLL_NO_REDIRECT=0
